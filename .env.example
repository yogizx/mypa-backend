# ── Email delivery ──────────────────────────────────────────────────────────
# Render's free tier blocks ALL outbound SMTP ports (25, 465, 587) — this is a
# hard network firewall rule (since Sep 2025), not a provider issue. SMTP will
# NOT work in production on Render regardless of which host you point it at.
#
# PRODUCTION (Render) — required:
#   Sign up at https://resend.com → API Keys → Create API Key, then set:
RESEND_API_KEY=re_your_resend_api_key_here
#
# LOCAL DEV ONLY — used automatically as a fallback when RESEND_API_KEY is
# unset (your machine's outbound ports aren't blocked, so Gmail works fine):
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your@gmail.com
SMTP_PASS=your_gmail_app_password
REMINDER_FROM_EMAIL=your@gmail.com
