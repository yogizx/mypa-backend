# MY PA Backend
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/mypa?retryWrites=true&w=majority

# JWT
JWT_ACCESS_SECRET=your_long_random_access_secret
JWT_REFRESH_SECRET=your_long_random_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# Email — Option A: SendGrid (recommended for Render)
SENDGRID_API_KEY=your_sendgrid_api_key

# Email — Option B: Custom SMTP (Gmail, etc.)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your_gmail_app_password

REMINDER_FROM_EMAIL=noreply@mypa.app
CLIENT_ORIGIN=http://localhost

# Push Notifications (FCM) — Firebase Admin SDK
# Get these values from Firebase Console → Project Settings → Service Accounts → Generate new private key
# FIREBASE_PROJECT_ID=my-pa-fb30c
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@my-pa-fb30c.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
